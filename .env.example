ANTHROPIC_API_KEY=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Optional: selects Slack's seed-data context; defaults to the first seed.
SLACK_SCENARIO_ID=raise-conversation

# Client (Vite) — backend origin (no trailing slash). Paths use `${VITE_API_URL}/api/...`.
# Local:  http://localhost:5000
# Deploy: https://the-third-voice-backend.onrender.com
VITE_API_URL=http://localhost:5000

# Server listen port (Render sets PORT automatically).
PORT=5000
