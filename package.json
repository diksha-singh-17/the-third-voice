{
  "name": "the-third-voice",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"tsx watch server/src/index.ts\" \"vite --config client/vite.config.ts\"",
    "build": "tsc -p server/tsconfig.json && vite build --config client/vite.config.ts",
    "start": "node server/dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
